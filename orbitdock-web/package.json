{
  "name": "orbitdock-web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --import ./tests/register.js --test 'tests/**/*.test.{js,jsx}'",
    "test:watch": "node --import ./tests/register.js --test --watch 'tests/**/*.test.{js,jsx}'",
    "test:e2e": "npx playwright test",
    "lint": "biome check src tests e2e",
    "lint:fix": "biome check --fix src tests e2e",
    "format": "biome format --write src tests e2e",
    "format:check": "biome format src tests e2e",
    "ci": "biome ci src tests e2e"
  },
  "dependencies": {
    "@preact/signals": "^2.1.0",
    "lucide-preact": "^0.511.0",
    "marked": "^15.0.7",
    "preact": "^10.26.6",
    "wouter-preact": "^3.7.2",
    "xstate": "^5.19.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.10.1",
    "@testing-library/preact": "^3.2.4",
    "esbuild": "^0.27.0",
    "happy-dom": "^18.0.1",
    "vite": "^8.0.0"
  }
}
